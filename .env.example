# ─────────────────────────────────────────────────────────────────────────────
# Vetor Blog - Environment Variables Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values

# ── Site URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.vetor.blog

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI Services ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
OPENROUTER_API_KEY=your-openrouter-api-key

# ── Mercado Livre ─────────────────────────────────────────────────────────────
ML_CLIENT_ID=your-ml-client-id
ML_CLIENT_SECRET=your-ml-client-secret
ML_REDIRECT_URI=https://www.vetor.blog/auth/callback

# ── Google Search Console ─────────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour Private Key\n-----END PRIVATE KEY-----"

# ── IndexNow (Bing) ──────────────────────────────────────────────────────────
INDEXNOW_API_KEY=your-indexnow-api-key

# ── Analytics & Tracking ──────────────────────────────────────────────────────
# Microsoft Clarity (free) - https://clarity.microsoft.com
NEXT_PUBLIC_CLARITY_ID=x1twakbx6h

# Google Analytics 4 (free) - https://analytics.google.com
NEXT_PUBLIC_GA_ID=G-9D57MBBJN7

# Facebook Pixel (optional) - https://business.facebook.com
NEXT_PUBLIC_FB_PIXEL_ID=your-pixel-id

# ── Error Monitoring ──────────────────────────────────────────────────────────
# Sentry (free tier) - https://sentry.io
SENTRY_DSN=https://your-sentry-dsn
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project

# ── Google AdSense ────────────────────────────────────────────────────────────
NEXT_PUBLIC_AD_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
NEXT_PUBLIC_AD_SLOT=xxxxxxxxxx

# ── GitHub (for autonomous agent) ─────────────────────────────────────────────
GITHUB_TOKEN=your-github-token
GITHUB_REPO=carloshbhb/Vetor

# ── Auth ──────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=your-email@domain.com
JWT_SECRET=your-jwt-secret-min-32-chars